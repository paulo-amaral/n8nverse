#!/bin/sh
set -eu

blocked_paths='(^|/)\.env$|(^|/).*\.pem$|(^|/).*\.key$|(^|/).*\.crt$|(^|/)data/|(^|/)certs/|(^|/)local-files/'

staged_files="$(git diff --cached --name-only)"

if [ -z "$staged_files" ]; then
  exit 0
fi

echo "$staged_files" | grep -E "$blocked_paths" >/dev/null 2>&1 && {
  echo "pre-commit: blocked sensitive or local-only files detected in the index." >&2
  echo "$staged_files" | grep -E "$blocked_paths" >&2 || true
  echo "pre-commit: remove them from the commit before retrying." >&2
  exit 1
}

if printf '%s\n' "$staged_files" | grep -Eq '(^|/)\.env\.example$'; then
  if git diff --cached -- .env.example | grep -E '^\+.*(POSTGRES_PASSWORD=)' >/dev/null 2>&1; then
    if git diff --cached -- .env.example | grep -E '^\+POSTGRES_PASSWORD=' | grep -Ev 'change_me|example|your_|replace_me|^\+POSTGRES_PASSWORD=$' >/dev/null 2>&1; then
      echo "pre-commit: review .env.example to avoid committing a real database password." >&2
      exit 1
    fi
  fi
fi

if [ -f compose.yaml ]; then
  docker compose config >/dev/null
fi
