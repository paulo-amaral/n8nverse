# Copy this file to `.env` before starting:
#   cp .env.example .env
#
# This project expects PostgreSQL to run on the host machine, outside Docker.
# For Docker Desktop on macOS, `host.docker.internal` is the usual host alias.

# PostgreSQL connection used by n8n
# Prefer a dedicated low-privilege user instead of the `postgres` superuser.
POSTGRES_USER=n8n_app
POSTGRES_PASSWORD=change_me_to_a_real_password
POSTGRES_DB=n8n
DB_POSTGRESDB_HOST=host.docker.internal
DB_POSTGRESDB_PORT=5432

# n8n encryption key
# Generate a long random value before first real use, for example:
#   openssl rand -hex 32
#
# Example:
#   N8N_ENCRYPTION_KEY=$(openssl rand -hex 32)
#
# Important:
# - Keep this value stable after the instance has been created
# - Changing it later can break access to encrypted credentials already stored by n8n
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_alpha_numeric_string
